{
  "name": "mcp-llm-studio",
  "mcpName": "io.github.mecha1610/mcp-llm-studio",
  "version": "3.1.5",
  "description": "MCP server bridging Claude Code (and other MCP clients) to a local LM Studio instance. Exposes model lifecycle (list/load/unload/download), single-turn inference with reasoning and stats, multi-turn chat with SQLite-persisted history, and embeddings.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "mcp-llm-studio": "dist/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "mecha1610",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mecha1610/mcp-llm-studio.git"
  },
  "bugs": {
    "url": "https://github.com/mecha1610/mcp-llm-studio/issues"
  },
  "homepage": "https://github.com/mecha1610/mcp-llm-studio#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lm-studio",
    "claude",
    "claude-code",
    "llm",
    "local-llm",
    "ai"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/server.js",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
